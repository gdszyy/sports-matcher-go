{
  "version": "2026-04-15",
  "purpose": "用于联赛匹配中的强约束校验；地区、性别、年龄、区域、赛制形态等关键词一旦显式出现，LS 与 TS 必须保持一致或满足可接受同义映射，否则直接否决候选。",
  "country_alias_groups": [
    ["england", "english"],
    ["scotland", "scottish"],
    ["greece", "greek"],
    ["italy", "italian"],
    ["brazil", "brazilian"],
    ["argentina", "argentinian", "argentine"],
    ["finland", "finnish"],
    ["hungary", "hungarian"],
    ["serbia", "serbian"],
    ["poland", "polish"],
    ["slovenia", "slovenian"],
    ["czech republic", "czech"],
