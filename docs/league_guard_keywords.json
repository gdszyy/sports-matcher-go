    ["netherlands", "dutch"],
    ["germany", "german"],
    ["france", "french"],
    ["spain", "spanish"],
    ["portugal", "portuguese"],
    ["turkey", "turkish"],
    ["mexico", "mexican"],
    ["japan", "japanese"],
    ["korea", "korean", "south korea"],
    ["china", "chinese"],
    ["russia", "russian"],
    ["austria", "austrian"],
    ["switzerland", "swiss"],
