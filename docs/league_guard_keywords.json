  "hard_constraints": [
    {
      "name": "country_or_region_must_match",
      "description": "若 LS 名称或 category 中可解析出国家或地区，而 TS 候选名称中出现另一国家或地区，则直接否决。对于 International/World/Global 仅允许映射到同类国际赛事。ASEAN 等洲际联盟词不约束具体国家。",
      "veto_examples": [
        "FA Cup (China) → FANS Cup: 中国 vs 无国家，名称 Jaccard 虚高，应否决",
        "The Championship (England) → ASEAN Championship: 英格兰 vs 东南亚，应否决"
      ]
    },
    {
      "name": "gender_must_match",
      "description": "Women/Female/Girls 与 Men/Male/Boys 不得互相吸附；一侧显式出现女性关键词而另一侧缺失或显式为男性时，直接否决。",
      "veto_examples": [
        "UEFA European Championship U19 Women → UEFA European Championship: 女性 vs 无性别标注，应否决"
      ]
    },
    {
      "name": "age_must_match",
      "description": "U23、U21、U19 等年龄层必须逐级一致；Youth/Reserve 只能映射到同类青年或预备队赛事。一侧有年龄标注而另一侧缺失时，直接否决。",
      "veto_examples": [
        "Premier League U19 → Premier League: U19 vs 无年龄，应否决"
      ]
    },
    {
      "name": "region_split_must_match",
      "description": "North/South/East/West/Central 等区域分区必须一致；例如 National League South 不能映射到 National League 或 National League North。一侧有区域分区标注而另一侧缺失时，直接否决。",
      "veto_examples": [
        "National League South → English National League: South 分区 vs 无分区，应否决",
        "National League South → National League North: South vs North，应否决"
      ]
    },
    {
      "name": "competition_type_must_match",
      "description": "Cup 与 League 原则上不得互相映射；Short-format/5x5/Futsal/Indoor/Amateur/LFL 等特殊赛制必须同类匹配。",
      "veto_examples": [
        "BudnesLiga LFL 5x5 (International) → Bundesliga: 5x5 特殊赛制 vs 标准联赛，应否决",
        "FA Cup (China) → FANS Cup: 两者均为 Cup 类型，但国家不匹配，优先由国家约束否决"
      ]
    },
    {
      "name": "tier_number_must_match",
      "description": "当候选仅为 NAME_LOW 或 NAME_MED，且联赛名称中出现明确的层级数字（如 Liga 3、4 Liga、2.Bundesliga）时，若两侧层级数字不一致则直接否决。NAME_HI 置信度下允许放行（已知映射白名单场景）。",
      "veto_examples": [
        "4 Liga (Poland) → Poland Liga 3: 层级 4 vs 层级 3，NAME_MED 置信度下应否决",
        "2.Bundesliga → Bundesliga: 层级 2 vs 层级 1（顶级），NAME_MED 置信度下应否决"
      ]
    }
  ],
  "allowlist_notes": [
    "允许官方长短名差异、品牌冠名差异、语言转写差异、历史别名差异。",
    "允许 country_alias_groups 内的国家词同义映射，例如 Greece 与 Greek、Germany 与 German。",
    "允许联赛名称中的国家词与 category/country 字段中的国家词通过 alias_groups 对齐，无需完全字符串匹配。",
    "不得因为存在 allowlist 而覆盖 gender、age、region、competition_type、tier_number 的强冲突。",
    "已知映射表（KnownLSLeagueMap / KnownLeagueMap）中的条目视为人工审核白名单，跳过强约束校验。"
  ]
}